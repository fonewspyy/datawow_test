# ========================================
# Concert Reservation — Monorepo .gitignore
# ========================================

# ---------- Dependencies ----------
node_modules/

# ---------- Build outputs ----------
dist/
.next/
out/
build/

# ---------- Environment ----------
# Block secrets but KEEP .env.example for easy setup
.env
.env.local
.env.*.local
!.env.example

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- IDE ----------
.idea/
*.swp
*.swo

# ---------- Debug logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Test / Coverage ----------
coverage/

# ---------- TypeScript ----------
*.tsbuildinfo

# ---------- Docker ----------
postgres-data/

# ---------- Misc ----------
*.pem
.vercel
